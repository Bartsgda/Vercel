<Files "consultations.json">
  Order Allow,Deny
  Deny from all
</Files>

# Wersja PHP (oryginalna z serwera webd.pl)
AddHandler application/x-httpd-php83 php

# TERAPIA - Konfiguracja
# ----------------------------

# 1. Bezpieczeństwo
Options -Indexes
ServerSignature Off

# Blokada直接 dostępu do plików danych w tym folderze
<FilesMatch "\.(json|log|sh|txt|bak|old)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Pozwól na dostęp do niezbędnych plików konfiguracyjnych dla JS
<Files "chapters.json">
    Order allow,deny
    Allow from all
</Files>
<Files "events.json">
    Order allow,deny
    Allow from all
</Files>

# 2. Kodowanie
AddDefaultCharset UTF-8

# 3. Reguły Rewrite (Clean URLs & HTTPS)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Wymuszenie HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Clean URLs dla Rozdziałów
    RewriteRule ^chapter/([a-zA-Z0-9_-]+)/?$ chapter.php?id=$1 [L,QSA]

    # Obsługa brakujących .php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>
