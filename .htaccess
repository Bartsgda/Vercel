# TERAPIA - Minimalna konfiguracja pod webd.pl
# ----------------------------

# 1. Wersja PHP (oryginalna z serwera)
# AddHandler application/x-httpd-php83 php

# 2. Kodowanie
AddDefaultCharset UTF-8

# 3. Podstawowy Rewrite (jeśli SSL jest włączony, usuń komentarz)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Przekierowanie /chapter/id -> chapter.php?id=id
    RewriteRule ^chapter/([a-zA-Z0-9_-]+)/?$ chapter.php?id=$1 [L,QSA]
</IfModule>
